# Förderly – Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte aus.
# NIEMALS .env.local committen!

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Supabase Service Key (nur für Migration/Scraper, NICHT im Frontend!)
SUPABASE_SERVICE_KEY=eyJxxx...

# Claude API (optional, für AI-Zusammenfassungen)
ANTHROPIC_API_KEY=sk-ant-XXXX

# App-Einstellungen
NEXT_PUBLIC_APP_URL=http://localhost:3000
